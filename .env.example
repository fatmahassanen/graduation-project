# Application Configuration
APP_NAME="University CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Security
BCRYPT_ROUNDS=12

# Logging Configuration
# Channels: stack, single, daily, slack, syslog, errorlog
# In production, use 'daily' for automatic log rotation
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# Development: Use sqlite for simplicity
# Production: Use mysql with proper credentials
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=university_cms
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting & Filesystem
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue Configuration
# Development: Use 'sync' or 'database' for immediate execution
# Production: Use 'redis' for better performance
QUEUE_CONNECTION=database
# REDIS_QUEUE_CONNECTION=default
# REDIS_QUEUE=default

# Cache Configuration
# Development: Use 'file' or 'database' for simplicity
# Production: Use 'redis' for better performance
CACHE_STORE=database
# CACHE_PREFIX=

# Redis Configuration
# Required for production cache and queue drivers
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Memcached Configuration (alternative to Redis)
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Mail Configuration
# Development: Use 'log' to write emails to log files
# Production: Use 'smtp' with real mail server credentials
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using S3 for media storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite Asset Compilation
VITE_APP_NAME="${APP_NAME}"
